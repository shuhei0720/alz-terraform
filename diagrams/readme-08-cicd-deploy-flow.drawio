                </mxCell>
                <mxCell id="s1" value="&lt;b&gt;1. feature ブランチ作成&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px;color:#888&#39;&gt;git checkout -b feature/xxx&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;strokeWidth=2;fontSize=12;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="60" width="240" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="s2" value="&lt;b&gt;2. コード編集 &amp;amp; コミット&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px;color:#888&#39;&gt;*.tf ファイルを編集 → git commit&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;strokeWidth=2;fontSize=12;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="120" width="240" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="2" style="edgeStyle=none;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=5;" edge="1" parent="1" source="s3" target="s4">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="s3" value="&lt;b&gt;3. Push &amp;amp; PR 作成&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px;color:#888&#39;&gt;git push → GitHub で Pull Request 作成&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;strokeWidth=2;fontSize=12;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="182.5" width="240" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="s4" value="&lt;b style=&#39;color:#2e7d32&#39;&gt;4. CI 自動実行&lt;/b&gt;（Terraform CI）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;strokeWidth=2;fontSize=12;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="400" y="190" width="280" height="40" as="geometry"/>
                </mxCell>
