                <mxCell id="tjWErpPhKR5l5U3wR7ji-2" value="&lt;b&gt;1. feature ブランチ作成&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px;color:#888&#39;&gt;git checkout -b feature/xxx&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;strokeWidth=2;fontSize=12;shadow=1;" vertex="1" parent="1">
