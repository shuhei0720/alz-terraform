                <mxCell id="tjWErpPhKR5l5U3wR7ji-6" value="&lt;b style=&#39;color:#2e7d32&#39;&gt;4. CI 自動実行&lt;/b&gt;（Terraform CI）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;strokeWidth=2;fontSize=12;shadow=1;" vertex="1" parent="1">
