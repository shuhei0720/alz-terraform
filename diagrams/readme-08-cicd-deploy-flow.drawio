                <mxCell id="s5" value="&lt;b&gt;5. レビュー &amp;amp; 承認&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px;color:#888&#39;&gt;plan 差分を確認 → Approve&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;strokeWidth=2;fontSize=12;shadow=1;" parent="1" vertex="1">
