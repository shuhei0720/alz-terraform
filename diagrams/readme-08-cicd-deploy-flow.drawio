                <mxCell id="tjWErpPhKR5l5U3wR7ji-5" value="&lt;b&gt;3. Push &amp;amp; PR 作成&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px;color:#888&#39;&gt;git push → GitHub で Pull Request 作成&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;strokeWidth=2;fontSize=12;shadow=1;" vertex="1" parent="1">
