    <diagram id="readme08" name="CI/CD デプロイフロー">
        <mxGraphModel dx="210216" dy="106416" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="860" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
