{
  "name": "IaC-Compliance-Initiative",
  "type": "Microsoft.Authorization/policySetDefinitions",
  "apiVersion": "2021-06-01",
  "properties": {
    "displayName": "IaC準拠チェックポリシーセット",
    "description": "Terraform等のIaCツールで管理されていないリソースを検出するポリシーセット。Azure自動作成リソースやポリシー(DINE)デプロイリソースは除外可能",
    "policyType": "Custom",
    "metadata": {
      "category": "Tags",
      "version": "2.0.0",
      "source": "Custom"
    },
    "parameters": {
      "auditNonTerraformEffect": {
        "type": "String",
        "metadata": {
          "displayName": "非Terraformリソース検出の効果",
          "description": "deployed_byタグがterraformでないリソースに対するアクション"
        },
        "allowedValues": ["Audit", "Deny", "Disabled"],
        "defaultValue": "Audit"
      },
      "excludedResourceTypes": {
        "type": "Array",
        "metadata": {
          "displayName": "除外リソースタイプ",
          "description": "IaC準拠チェックから除外するリソースタイプ（Azure自動作成・ポリシーDINEデプロイ等）"
        },
        "defaultValue": [
          "microsoft.network/networkwatchers",
          "microsoft.eventgrid/systemtopics",
          "microsoft.insights/activitylogalerts",
          "microsoft.insights/metricalerts",
          "microsoft.insights/actiongroups",
          "microsoft.security/automations",
          "microsoft.alertsmanagement/actionrules",
          "microsoft.operationsmanagement/solutions"
        ]
      }
    },
    "policyDefinitions": [
      {
        "policyDefinitionReferenceId": "AuditNonTerraformResources",
        "policyDefinitionId": "/providers/Microsoft.Management/managementGroups/placeholder/providers/Microsoft.Authorization/policyDefinitions/Audit-Non-Terraform-Resources",
        "parameters": {
          "effect": {
            "value": "[parameters('auditNonTerraformEffect')]"
          },
          "tagName": {
            "value": "deployed_by"
          },
          "tagValue": {
            "value": "terraform"
          },
          "excludedResourceTypes": {
            "value": "[parameters('excludedResourceTypes')]"
          }
        }
      }
    ]
  }
}
